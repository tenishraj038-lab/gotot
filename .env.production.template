# =============================================================================
# GoToT Production Environment Variables
# Copy this to your Render/Vercel dashboard - NEVER commit secrets to git
# =============================================================================

# --- Security ---
SECRET_KEY=generate-a-random-64-char-secret-here-using-openssl-rand-hex-32

# --- Database (Supabase PostgreSQL) ---
# Get these from Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_SUPABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- Redis (Upstash) ---
# Get these from Upstash Console > Your Database > REST API
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_REGION-YOUR_ENDPOINT.upstash.io:6379
CELERY_BROKER_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_REGION-YOUR_ENDPOINT.upstash.io:6379/1

# --- Environment ---
ENVIRONMENT=production
LOG_LEVEL=info

# --- CORS / Origins ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://gotot.vercel.app,https://gotot-api.onrender.com
FRONTEND_URL=https://gotot.vercel.app

# --- File Downloads ---
DOWNLOAD_DIR=/tmp/downloads
DOWNLOAD_TIMEOUT=300
INFO_TIMEOUT=30
CACHE_TTL=3600
FILE_RETENTION_HOURS=1
MAX_FILE_SIZE_MB=500

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Razorpay (Payments) ---
# Get from Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET
RAZORPAY_WEBHOOK_SECRET=generate-a-random-webhook-secret
RAZORPAY_PRO_PLAN_ID=plan_XXXXXXXXXXXXXX
RAZORPAY_UNLIMITED_PLAN_ID=plan_XXXXXXXXXXXXXX
CURRENCY=USD

# --- SMTP / Email ---
# Use SendGrid, Mailgun, or any SMTP provider
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=YOUR_SENDGRID_API_KEY
SMTP_FROM_EMAIL=noreply@gotot.app
ADMIN_EMAIL=admin@gotot.app

# --- Google OAuth ---
# Get from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://gotot.vercel.app/auth/google/callback

# --- Sentry (Error Monitoring) ---
# Get from sentry.io > Your Project > SDK Setup
SENTRY_DSN=https://YOUR_PUBLIC_KEY@oXXXXXX.ingest.us.sentry.io/XXXXXX

# --- Frontend-specific env (set in Vercel dashboard) ---
# NEXT_PUBLIC_API_URL=/api
# NEXT_PUBLIC_WS_URL=wss://gotot-api.onrender.com
