# ┌─────────────────────────────────────────────────────────────┐
# │                     GoTot Environment Variables              │
# │              Copy to .env and fill in your values            │
# └─────────────────────────────────────────────────────────────┘

# ── Core ────────────────────────────────────────────────────
SECRET_KEY=generate-a-random-64-char-secret-here-at-least-32-chars
ENVIRONMENT=production                # development | production
LOG_LEVEL=info                         # debug | info | warning | error

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gotot:your_secure_password@postgres:5432/gotot

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://your-admin-domain.com
MAX_FILE_SIZE_MB=500
MAX_REQUEST_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_DOWNLOAD_PER_MINUTE=10

# ── Domains ───────────────────────────────────────────────────
# Comma-separated list of allowed download domains. Use "*" for all.
ALLOWED_DOMAINS=*

# ── Storage ───────────────────────────────────────────────────
DOWNLOAD_DIR=/tmp/downloads
TEMP_DIR=/tmp/gotot_temp
FILE_RETENTION_HOURS=1
CLEANUP_INTERVAL_SECONDS=3600

# ── Timeouts ──────────────────────────────────────────────────
DOWNLOAD_TIMEOUT=300
INFO_TIMEOUT=30
CACHE_TTL=3600

# ── JWT ──────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.com

# ── Payments (Razorpay) ──────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_UNLIMITED_PLAN_ID=
CURRENCY=USD

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@gotot.app
ADMIN_EMAIL=admin@gotot.app
SUPPORT_EMAIL=support@gotot.app
DMCA_EMAIL=dmca@gotot.app
PRIVACY_EMAIL=privacy@gotot.app

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-frontend-domain.com/auth/google/callback

# ── Sentry (Error Monitoring) ────────────────────────────────
SENTRY_DSN=

# ── CSRF ─────────────────────────────────────────────────────
CSRF_COOKIE_NAME=csrf_token
CSRF_COOKIE_SECURE=true
CSRF_COOKIE_HTTPONLY=true
CSRF_COOKIE_SAMESITE=lax

# ── Request ID ───────────────────────────────────────────────
REQUEST_ID_HEADER=X-Request-ID

