SECRET_KEY=generate-a-random-64-char-secret
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/gotot
REDIS_URL=redis://user:pass@host:6379/0
CELERY_BROKER_URL=redis://user:pass@host:6379/1
CELERY_RESULT_BACKEND=redis://user:pass@host:6379/0
ENVIRONMENT=production
LOG_LEVEL=info
ALLOWED_ORIGINS=https://gotot.railway.app,https://your-domain.com
FRONTEND_URL=https://your-frontend.railway.app
CURRENCY=USD
