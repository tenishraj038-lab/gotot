{
  "manifest_version": 3,
  "name": "GoTot Video Downloader",
  "version": "1.0.0",
  "description": "Download videos from YouTube, TikTok, Instagram, Twitter, and more with one click.",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": ["*://*.youtube.com/*", "*://*.tiktok.com/*", "*://*.instagram.com/*", "*://*.twitter.com/*", "*://*.x.com/*", "*://*.facebook.com/*", "*://*.reddit.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "GoTot - Download this video"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.tiktok.com/*", "*://*.instagram.com/*", "*://*.twitter.com/*", "*://*.x.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
