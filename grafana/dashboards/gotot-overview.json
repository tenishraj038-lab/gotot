{
  "title": "GoTot Production Overview",
  "uid": "gotot-overview",
  "version": 1,
  "timezone": "utc",
  "editable": false,
  "panels": [
    {
      "title": "Request Rate",
      "type": "graph",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "rate(http_requests_total[5m])", "legendFormat": "{{status}}"}]
    },
    {
      "title": "p95 Latency",
      "type": "graph",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"}]
    },
    {
      "title": "Error Rate",
      "type": "graph",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])", "legendFormat": "error %"}]
    },
    {
      "title": "Active Users",
      "type": "stat",
      "gridPos": {"x": 0, "y": 8, "w": 4, "h": 6},
      "targets": [{"expr": "gotot_active_users", "legendFormat": "users"}]
    },
    {
      "title": "Downloads Today",
      "type": "stat",
      "gridPos": {"x": 4, "y": 8, "w": 4, "h": 6},
      "targets": [{"expr": "gotot_downloads_today", "legendFormat": "downloads"}]
    },
    {
      "title": "Revenue (MTD)",
      "type": "stat",
      "gridPos": {"x": 8, "y": 8, "w": 4, "h": 6},
      "targets": [{"expr": "gotot_revenue_mtd", "legendFormat": "revenue"}]
    },
    {
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": {"x": 12, "y": 8, "w": 4, "h": 6},
      "targets": [{"expr": "gotot_queue_pending", "legendFormat": "pending"}]
    },
    {
      "title": "Queue Performance",
      "type": "graph",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 6},
      "targets": [
        {"expr": "gotot_queue_pending", "legendFormat": "pending"},
        {"expr": "gotot_queue_processing", "legendFormat": "processing"}
      ]
    },
    {
      "title": "Downloads by Platform (30d)",
      "type": "piechart",
      "gridPos": {"x": 0, "y": 14, "w": 8, "h": 8},
      "targets": [{"expr": "gotot_downloads_by_platform", "legendFormat": "{{platform}}"}]
    },
    {
      "title": "Premium Conversion",
      "type": "graph",
      "gridPos": {"x": 8, "y": 14, "w": 8, "h": 8},
      "targets": [
        {"expr": "rate(gotot_premium_signups_total[7d])", "legendFormat": "signups"},
        {"expr": "rate(gotot_cancellations_total[7d])", "legendFormat": "cancellations"}
      ]
    },
    {
      "title": "System Resources",
      "type": "graph",
      "gridPos": {"x": 16, "y": 14, "w": 8, "h": 8},
      "targets": [
        {"expr": "node_memory_usage_percent", "legendFormat": "memory"},
        {"expr": "node_cpu_usage_percent", "legendFormat": "cpu"}
      ]
    }
  ]
}
